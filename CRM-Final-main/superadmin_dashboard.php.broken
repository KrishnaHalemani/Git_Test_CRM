<script>
function showEditBranchModal(id, name) {
    document.getElementById('editBranchId').value = id;
    document.getElementById('editBranchName').value = name;
    var modal = new bootstrap.Modal(document.getElementById('editBranchModal'));
    modal.show();
}
</script>

<script>
// Refresh dashboard charts via AJAX
function refreshDashboardCharts() {
    fetch('api/dashboard_stats.php', {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
        // Update Chart.js instances
        if(window.leadsChart && window.revenueChart && window.sourceChart) {
            leadsChart.data.labels = data.monthLabels;
            leadsChart.data.datasets[0].data = data.monthlyLeads;
            if(leadsChart.data.datasets[1]) {
                leadsChart.data.datasets[1].data = data.monthlyConverted;
            }
            leadsChart.update();

            revenueChart.data.labels = data.monthLabels;
            revenueChart.data.datasets[0].data = data.revenueData;
            revenueChart.update();

            sourceChart.data.labels = data.sourceLabels;
            sourceChart.data.datasets[0].data = data.sourceDataArr;
            sourceChart.update();
        }
    });
}

// AJAX create branch
document.getElementById('createBranchForm').addEventListener('submit', function(e){
    e.preventDefault();
    var form = e.target;
    var fd = new FormData(form);
    fd.append('ajax', '1');
    fetch(location.href, { method: 'POST', body: fd }).then(r=>r.json()).then(data=>{
        if(data.success){
            // add option to all branch selects
            var selects = document.querySelectorAll('select[name="branch"]');
            selects.forEach(function(s){
                var opt = document.createElement('option');
                opt.value = data.name;
                opt.textContent = data.name;
                s.appendChild(opt);
                s.value = data.name;
            });

            // add row to branches table
            var tbody = document.getElementById('branchesTableBody');
            if(tbody){
                var tr = document.createElement('tr');
                tr.id = 'branch-row-' + data.id;
                tr.innerHTML = '<td>'+escapeHtml(data.name)+'</td>' +
                    '<td><form method="POST" class="d-inline branch-delete-form"><input type="hidden" name="branch_id" value="'+data.id+'"><input type="hidden" name="branch_action" value="delete_branch"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm(\'Delete branch?\');"><i class="fas fa-trash"></i></button></form> <button class="btn btn-sm btn-warning" onclick="showEditBranchModal('+data.id+', \'"+escapeJs(data.name)+"\')"><i class="fas fa-edit"></i></button></td>';
                tbody.appendChild(tr);
            }

            // close modal
            var modalEl = document.getElementById('createBranchModal');
            var modal = bootstrap.Modal.getInstance(modalEl);
            modal.hide();

            // clear form
            form.reset();

            // Refresh charts
            refreshDashboardCharts();
        } else {
            alert('Error: '+(data.error||'Could not create branch'));
        }
    }).catch(err=>{ alert('Network error'); });
});

// AJAX edit branch
document.getElementById('editBranchForm').addEventListener('submit', function(e){
    e.preventDefault();
    var form = e.target;
    var fd = new FormData(form);
    fd.append('ajax', '1');
    fetch(location.href, { method: 'POST', body: fd }).then(r=>r.json()).then(data=>{
        if(data.success){
            // update option values in selects
            var selects = document.querySelectorAll('select[name="branch"]');
            selects.forEach(function(s){
                for(var i=0;i<s.options.length;i++){
                    if(s.options[i].value === data.name || s.options[i].value === s.options[i].value){ /* noop to avoid lint */ }
                }
            });

            // update branch row
            var row = document.getElementById('branch-row-' + data.id);
            if(row) row.children[0].textContent = data.name;

            var modalEl = document.getElementById('editBranchModal');
            var modal = bootstrap.Modal.getInstance(modalEl);
            modal.hide();

            // Refresh charts
            refreshDashboardCharts();
        } else {
            alert('Error: '+(data.error||'Could not update branch'));
        }
    }).catch(err=>{ alert('Network error'); });
});

// Helper escape functions
function escapeHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/\'/g,'&#39;'); }
function escapeJs(s){ return String(s).replace(/\\/g,'\\\\').replace(/'/g,'\\\'').replace(/"/g,'\\"'); }

// Intercept delete forms to do AJAX delete and remove row
document.addEventListener('submit', function(e){
    if(e.target && e.target.classList && e.target.classList.contains('branch-delete-form')){
        e.preventDefault();
        if(!confirm('Delete branch?')) return;
        var form = e.target;
        var fd = new FormData(form);
        fd.append('ajax','1');
        fetch(location.href, { method:'POST', body: fd }).then(r=>r.json()).then(data=>{
            if(data.success){
                var row = document.getElementById('branch-row-' + (fd.get('branch_id')));
                if(row) row.remove();
                // remove from selects
                document.querySelectorAll('select[name="branch"]').forEach(function(s){
                    for(var i=s.options.length-1;i>=0;i--){ if(s.options[i].value === fd.get('branch_id') || s.options[i].value === fd.get('branch_id')){ s.remove(i); } }
                });

                // Refresh charts
                refreshDashboardCharts();
            } else {
                alert('Error deleting branch');
            }
        }).catch(()=>alert('Network error'));
    }
});
</script>
</script>
